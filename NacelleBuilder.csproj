<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <PlatformTarget>x64</PlatformTarget>
    <RootNamespace>NacelleSolidWorks</RootNamespace>
    <AssemblyName>NacelleBuilder</AssemblyName>
    <OutputPath>bin\</OutputPath>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="src\AssemblyReviewBuilder.cs" />
    <Compile Include="src\NacelleConfig.cs" />
    <Compile Include="src\NacelleStage1Builder.cs" />
    <Compile Include="src\Program.cs" />
    <Compile Include="src\SwGeometry.cs" />
    <Compile Include="src\SwSession.cs" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="SolidWorks.Interop.sldworks">
      <HintPath>lib\SolidWorks.Interop.sldworks.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>
</Project>
